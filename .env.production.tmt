# TMT (Smart Money Radar) — production environment
# Preencha os valores antes de rodar deploy.sh

# --- Django ---
SECRET_KEY=CHANGE_ME_GERAR_SECRET_KEY
DEBUG=False
ALLOWED_HOSTS=tmt.trade,www.tmt.trade,localhost,127.0.0.1

# --- Database (TimescaleDB) ---
DATABASE_URL=postgres://tmt:CHANGE_ME_DB_PASSWORD@db:5432/tmt
POSTGRES_DB=tmt
POSTGRES_USER=tmt
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Hyperliquid API (public, no auth needed) ---
HL_API_URL=https://api.hyperliquid.xyz
HL_WS_URL=wss://api.hyperliquid.xyz/ws

# --- Telegram Alerts (opcional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# --- Alerts dedup ---
ALERT_DEDUP_COOLDOWN_SECONDS=3600

# --- TMT bridge (born disabled) ---
TMT_BRIDGE_ENABLED=False
TMT_BRIDGE_TOKEN=

# --- ACME (Traefik Let's Encrypt) ---
ACME_EMAIL=matheus.marinello@gmail.com

# --- Superuser bootstrap ---
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=matheus.marinello@gmail.com
DJANGO_SUPERUSER_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# --- Build/version ---
SMR_VERSION=1.0.0
