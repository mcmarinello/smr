# SMR — production environment template (PRD Sprint 10 §Deploy).
#
# Copy to .env.production and fill in real secrets before `./deploy.sh`.
# NEVER commit the filled-in file. The .gitignore already excludes .env*.

# --- Django ---
# Generate with: python3 -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-me-with-a-50-char-random-string
DEBUG=False
ALLOWED_HOSTS=smr.trade,www.smr.trade,localhost,127.0.0.1

# --- Database (TimescaleDB) ---
DATABASE_URL=postgres://smr:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/smr
POSTGRES_DB=smr
POSTGRES_USER=smr
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# --- Redis (broker + cache) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Hyperliquid public API ---
HYPERLIQUID_INFO_API_URL=https://api.hyperliquid.xyz/info
HYPERLIQUID_WS_URL=wss://api.hyperliquid.xyz/ws
HYPERLIQUID_RATE_LIMIT_WEIGHT_PER_MIN=1200

# --- Discovery tuning ---
DISCOVERY_MAX_STREAM_COINS=20
DISCOVERY_STREAM_DURATION_SECS=300

# --- Telegram (optional; bot must be created via @BotFather) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# --- Alerts dedup ---
ALERT_DEDUP_COOLDOWN_SECONDS=3600

# --- TMT bridge (born disabled; PRD §Sprint 9) ---
TMT_BRIDGE_ENABLED=False
TMT_BRIDGE_TOKEN=

# --- ACME (Traefik Let's Encrypt) ---
ACME_EMAIL=admin@smr.trade

# --- Superuser bootstrap (used only by ./deploy.sh) ---
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@smr.trade
DJANGO_SUPERUSER_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# --- Optional S3 backups (used by ./backup.sh) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_S3_REGION=us-east-1

# --- Build/version tag surfaced in /health/ ---
SMR_VERSION=1.0.0
